NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgres://user:password@host:5432/database

# Optional Google Books fallback. Keep the API key on the server only.
GOOGLE_BOOKS_API_KEY=

# Optional automatic translation for descriptions and other user-entered text.
# Enable Cloud Translation API (Basic v2) and keep this key on the server only.
GOOGLE_TRANSLATE_API_KEY=
