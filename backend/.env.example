PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-secret-before-cloud-deploy

# Optional PostgreSQL. If it is unavailable, the server uses backend/data/store.json.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bibliotech
DB_USER=postgres
DB_PASSWORD=postgres

# Optional Google Books fallback. Keep the API key on the server only.
GOOGLE_BOOKS_API_KEY=

# Optional automatic translation for descriptions and other user-entered text.
# Enable Cloud Translation API (Basic v2) and keep this key on the server only.
GOOGLE_TRANSLATE_API_KEY=
