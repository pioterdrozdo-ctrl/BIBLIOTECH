PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-secret-before-cloud-deploy

# Optional PostgreSQL. If it is unavailable, the server uses backend/data/store.json.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bibliotech
DB_USER=postgres
DB_PASSWORD=postgres

# Optional ISBN cascade providers. Keep API keys on the server only.
GOOGLE_BOOKS_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
