#!/usr/bin/env sh
set -eu

GRADLE_VERSION="9.4.1"
CACHE_ROOT="${GRADLE_USER_HOME:-$HOME/.gradle}/bibliotech-wrapper"
GRADLE_HOME="$CACHE_ROOT/gradle-$GRADLE_VERSION"
ARCHIVE="$CACHE_ROOT/gradle-$GRADLE_VERSION-bin.zip"

if [ ! -x "$GRADLE_HOME/bin/gradle" ]; then
    mkdir -p "$CACHE_ROOT"
    if [ ! -f "$ARCHIVE" ]; then
        echo "Downloading Gradle $GRADLE_VERSION..."
        curl -fL "https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip" -o "$ARCHIVE"
    fi
    rm -rf "$GRADLE_HOME"
    unzip -q "$ARCHIVE" -d "$CACHE_ROOT"
fi

exec "$GRADLE_HOME/bin/gradle" "$@"
