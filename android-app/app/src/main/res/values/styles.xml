<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Bibliotech" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/bibliotech_background</item>
        <item name="android:navigationBarColor">@color/bibliotech_background</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:colorAccent">@color/bibliotech_green</item>
    </style>

    <style name="Theme.Bibliotech.Launcher" parent="Theme.Bibliotech">
        <item name="android:windowBackground">@color/bibliotech_background</item>
        <item name="android:windowDisablePreview">false</item>
    </style>
</resources>
